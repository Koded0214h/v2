{
    "buildCommand": "vite build",
    "outputDirectory": "dist",
    "routes": [
      {
        "src": "/assets/(.*)",
        "headers": {
          "cache-control": "public, max-age=31536000, immutable"
        }
      },
      {
        "src": "/(.*\\.(png|jpg|jpeg|svg|ico|pdf|webp|gif|txt|xml))",
        "dest": "/$1"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }